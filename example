      .tips-column {
        flex: 1;
        min-width: 250px;
      }

      .tips-column h4 {
        margin-bottom: 15px;
      }

      details {
        margin-bottom: 12px;
        border: 1px solid #999;
        padding: 10px;
        background-color: white;
      }

      summary {
        cursor: pointer;
        font-weight: bold;
      }

      details p {
        margin-top: 10px;
        line-height: 1.5;
      }
    </style>
  </head>

  <body>
    <div class="header">
      <h1><a href="/index.html">UtilEasy</a></h1>

