    <div class="container">
      <div class="page-title">
        <h2>Saving Tips</h2>
      </div>

      <div class="tips-grid">

        <!-- Energy Saving -->
        <div class="tips-column">
          <h4>Energy Saving Tips</h4>

          <details>
            <summary>LED</summary>
            <p>
              LED light bulbs use less electricity and last longer than
              traditional bulbs.
            </p>
          </details>

          <details>
            <summary>Turn Off Devices</summary>
            <p>
              Switch off appliances and lights when not in use to reduce
              electricity usage.
            </p>
          </details>

          <details>
            <summary>Natural Lighting</summary>
            <p>
              Open curtains during the day to reduce the need for indoor lights.
            </p>
          </details>
        </div>

        <!-- Water Saving -->
        <div class="tips-column">
          <h4>Water Saving Tips</h4>

          <details>
            <summary>Short Showers</summary>
            <p>
              Reducing shower time helps save large amounts of water each week.
            </p>
          </details>

          <details>
            <summary>Fix Leaks</summary>
            <p>
              Repair leaking taps and pipes to prevent unnecessary water waste.
            </p>
          </details>

          <details>
            <summary>Full Loads Only</summary>
            <p>
              Use washing machines and dishwashers only when fully loaded.
            </p>
          </details>
        </div>

      </div>
    </div>
